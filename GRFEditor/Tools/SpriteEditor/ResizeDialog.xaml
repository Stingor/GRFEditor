<Styles:TkWindow x:Class="GRFEditor.Tools.SpriteEditor.ResizeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Styles="clr-namespace:TokeiLibrary.WPF.Styles;assembly=TokeiLibrary"
        xmlns:TokeiLibrary="clr-namespace:TokeiLibrary;assembly=TokeiLibrary"
        Width="300" Background="{DynamicResource TabItemBackground}" Foreground="{DynamicResource TextForeground}">
    <StackPanel>
        <Grid Margin="7 7 7 4">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Width (%):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" Name="_widthBox" Height="24" Margin="3 3 3 3"
                     VerticalContentAlignment="Center" Text="100" TextChanged="_widthBox_TextChanged"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Height (%):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" Name="_heightBox" Height="24" Margin="3 3 3 3"
                     VerticalContentAlignment="Center" Text="100" TextChanged="_heightBox_TextChanged"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Lock aspect ratio:" VerticalAlignment="Center"/>
            <CheckBox Grid.Row="2" Grid.Column="1" Name="_lockAspect" IsChecked="True"
                      Margin="5 0 0 0" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Scaling mode:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="3" Grid.Column="1" Name="_scalingMode" Margin="3 3 3 3"
                      VerticalContentAlignment="Center" SelectedIndex="0">
                <ComboBoxItem>Nearest Neighbor</ComboBoxItem>
                <ComboBoxItem>Bilinear</ComboBoxItem>
            </ComboBox>
        </Grid>
        <Grid TokeiLibrary:WpfProperties.IsDraggable="True" Height="40" Background="{DynamicResource UIDialogBackground}">
            <DockPanel HorizontalAlignment="Right" Margin="0 0 3 0">
                <Button Name="_buttonOk" Content="Ok" Width="100" Height="24" Margin="3" Click="_buttonOk_Click"/>
                <Button Name="_buttonCancel" Content="Cancel" Width="100" Height="24" Margin="3" Click="_buttonCancel_Click"/>
            </DockPanel>
        </Grid>
    </StackPanel>
</Styles:TkWindow>
